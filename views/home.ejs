<style>
  body.patric {
    min-width: 320px;
  }

  #p3header-search,
  #mobile-search-icon {
    display: none;
  }

  .home-main-left h1,
  .home-main-left h2 {
    margin-bottom: 0;
  }

  /* New styles for the corner image */
  .bv-brc-info {
    position: relative;
    overflow: hidden; /* This ensures the image doesn't overflow the container */
  }

  .corner-image {
    position: absolute;
    top: 10px;
    right: 10px;
    z-index: 0; /* Lower z-index to place behind content */
  }

  .corner-image img {
    max-width: 250px;
    height: auto;
    opacity: 0.2; /* Optional: make the image slightly transparent */
  }

  /* Add z-index to text content to ensure it appears above the image */
  .bv-brc-info h1,
  .bv-brc-info p,
  .bv-brc-info .search,
  .bv-brc-info .browse {
    position: relative;
    z-index: 1; /* Higher z-index to place content above the image */
  }

  /* Search Section Styles */
  .search-section {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 16px;
    background-color: #f9fdfc;
    margin-top: 20px;
    position: relative;
    z-index: 1;
  }

  .search-header {
    display: flex;
    align-items: center;
    margin-bottom: 12px;
  }

  .search-icon {
    font-size: 20px;
    font-weight: 600;
    margin-right: 8px;
  }

  .search-header h2 {
    margin: 0;
    font-size: 18px;
  }

  .search-input-container {
    display: flex;
    margin-bottom: 12px;
  }

  .search-input {
    flex: 1;
    padding: 10px;
    font-size: 14px;
    border: 1px solid #ccc;
    border-top-left-radius: 4px;
    border-bottom-left-radius: 4px;
  }

  .search-button {
    padding: 10px 16px;
    background-color: #2b5c7b;
    color: #fff;
    border: none;
    border-top-right-radius: 4px;
    border-bottom-right-radius: 4px;
    cursor: pointer;
  }

  .search-tags {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tags-label {
    font-weight: 500;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tag-button {
    background-color: #f0f0f0;
    border: 1px solid #ccc;
    border-radius: 16px;
    padding: 4px 12px;
    font-size: 13px;
    cursor: pointer;
    transition: background-color 0.2s;
  }

  .tag-button:hover {
    background-color: #e0e0e0;
  }

  /* Analyze Data Section Styles */
  .analyze-data-section {
    border: 1px solid #e0e0e0;
    border-radius: 8px;
    padding: 24px;
    background-color: #f9fdfc;
    margin-bottom: 20px;
  }

  .analyze-data-header {
    display: flex;
    align-items: center;
    margin-bottom: 8px;
  }

  .analyze-icon {
    font-size: 22px;
    font-weight: 600;
    margin-right: 8px;
  }

  .analyze-data-header h2 {
    margin: 0;
    font-size: 20px;
  }

  .analyze-description {
    font-size: 14px;
    color: #555;
    margin-bottom: 24px;
  }

  .analyze-cards-container {
    display: flex;
    gap: 16px;
    flex-wrap: nowrap;
    margin-bottom: 24px;
  }

  .analyze-card {
    flex: 1 1 200px;
    background-color: #f5faf7;
    padding: 16px;
    border-radius: 8px;
    border: 1px solid #ddd;
    min-width: 100px;
  }

  .analyze-card h3 {
    font-size: 16px;
    margin-bottom: 8px;
  }

  .analyze-card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 14px;
  }

  .analyze-card-list li {
    margin-bottom: 4px;
  }

  .analyze-card-list li a {
    text-decoration: none;
    color: inherit;
  }

  .analyze-card-list li a:hover {
    text-decoration: underline;
  }

  .analyze-card-list .view-all {
    margin-top: 8px;
  }

  .analyze-card-list .view-all a {
    color: #2b5c7b;
    cursor: pointer;
  }

  .analyze-buttons {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .analyze-button {
    padding: 8px 16px;
    font-size: 14px;
    border: 1px solid #ccc;
    border-radius: 6px;
    background-color: #fff;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
    display: inline-block;
    transition: background-color 0.2s;
  }

  .analyze-button:hover {
    background-color: #f0f0f0;
  }

  /* Media queries for better responsiveness */
  @media (max-width: 768px) {
    .analyze-card {
      flex: 1 1 100%;
    }
  }
</style>
