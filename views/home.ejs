        <div class="grid-container">
            <div class="home-main home-main-left">
                <div class="bv-brc-info card">
                    <h1 style="
                        font-family: 'Manrope', sans-serif;
                        font-weight: 700;
                        color: #2A3D4E;
                        font-size: 2rem;
                        ">
                        Midwest Alliance for Applied Genomic Epidemiology
                    </h1>
                    <p>
                        Welcome to the Midwest Alliance for Applied Genomic Epidemiology (MAAGE), a comprehensive
                        resource for bacterial and viral infectious disease research. MAAGE provides integrated data,
                        advanced bioinformatics tools, and workflows to support the scientific community in
                        understanding and combating infectious diseases. Explore our <a
                                href="https://www.maage.org/docs/quick_start/index.html" target="_blank"
                                style="font-weight: bold;">Quick Start Guide</a> to learn more about the platform's
                                features and capabilities. For questions or assistance, please don't hesitate to <a
                                href="mailto:help@maage.org" style="font-weight: bold;">contact us</a>.
                    </p>

                    <!-- Search Section Component -->
                    <div class="search-section">
                        <div class="search-header">
                            <span class="search-icon">🔍</span>
                            <h2>Search Data</h2>
                        </div>

                        <div class="search-input-container">
                            <input
                                type="text"
                                placeholder="Search genes, genomes, proteins, pathways..."
                                class="search-input"
                            />
                            <button class="search-button">Search 🔍</button>
                        </div>

                        <div class="search-tags">
                            <span class="tags-label">Popular:</span>
                            <div class="tags-container">
                                <button class="tag-button">SARS-CoV-2</button>
                                <button class="tag-button">Mpox</button>
                                <button class="tag-button">H5N1</button>
                                <button class="tag-button">Flu Surveillance</button>
                            </div>
                        </div>
                    </div>
                    <!-- End Search Section Component -->

                    <div class="corner-image">
                        <img src="/patric/images/maage/background-icon2.png" alt="MAAGE Logo">
                    </div>
                </div>

                <div class="bv-brc-mid"> <!-- style="grid-row: 3/6"-->
                    <div class="analyze-data-section">
                        <div class="analyze-data-header">
                            <span class="analyze-icon">🧪</span>
                            <h2>Analyze Data</h2>
                        </div>
                        <p class="analyze-description">
                            Upload and analyze your genomic data in a secure private workspace with our comprehensive suite of tools.
                        </p>

                        <div class="analyze-cards-container">
                            <div class="analyze-card">
                                <h3>🔍 Search</h3>
                                <ul class="analyze-card-list">
                                    <li><a href="/searches/TaxaSearch" class="navigationLink">Taxa</a></li>
                                    <li><a href="/searches/GenomeSearch" class="navigationLink">Genomes</a></li>
                                    <li><a href="/searches/FeatureSearch" class="navigationLink">Features</a></li>
                                    <li><a href="/searches/SpecialtyGeneSearch" class="navigationLink">Specialty Genes</a></li>
                                    <li class="view-all"><a href="/searches" class="navigationLink">View All →</a></li>
                                </ul>
                            </div>

                            <div class="analyze-card">
                                <h3>🧬 Analyze</h3>
                                <ul class="analyze-card-list">
                                    <li><a href="/app/Assembly2" class="navigationLink">Assembly</a></li>
                                    <li><a href="/app/Annotation" class="navigationLink">Annotation</a></li>
                                    <li><a href="/app/Homology" class="navigationLink">BLAST</a></li>
                                    <li><a href="/app/MSA" class="navigationLink">MSA</a></li>
                                    <li class="view-all"><a href="/tools" class="navigationLink">View All →</a></li>
                                </ul>
                            </div>

                            <div class="analyze-card">
                                <h3>🗃️ Data</h3>
                                <ul class="analyze-card-list">
                                    <li><a href="https://bv-brc.org/docs/quick_references/workspaces/workspace.html" target="_blank">Workspace</a></li>
                                    <li><a href="https://bv-brc.org/docs/quick_references/workspaces/groups.html" target="_blank">Save Results</a></li>
                                    <li><a href="https://bv-brc.org/docs/quick_references/workspaces/data_upload.html" target="_blank">Upload Data</a></li>
                                    <li><a href="https://bv-brc.org/docs/quick_references/workspaces/jobs.html" target="_blank">Analysis Jobs</a></li>
                                    <li class="view-all"><a href="https://bv-brc.org/docs/quick_references/workspaces/workspace.html#creating-and-sharing-workspaces" target="_blank">Share & Publish</a></li>
                                </ul>
                            </div>

                            <div class="analyze-card">
                                <h3>🔗 Access</h3>
                                <ul class="analyze-card-list">
                                    <li><a href="https://bv-brc.org/docs/cli_tutorial/index.html" target="_blank">CLI</a></li>
                                    <li><a href="https://bv-brc.org/api/doc/" target="_blank">API</a></li>
                                    <li><a href="https://bv-brc.org/docs/quick_references/ftp.html" target="_blank">FTP</a></li>
                                    <li class="view-all"><a href="https://bv-brc.org/docs/quick_references/index.html" target="_blank">View All →</a></li>
                                </ul>
                            </div>
                        </div>

                        <div class="analyze-buttons">
                            <a href="https://bv-brc.org/docs/quick_start/index.html" class="analyze-button navigationLinkOut">Quick Start</a>
                            <a href="https://bv-brc.org/docs/quick_references/index.html" class="analyze-button navigationLinkOut">Reference Guides</a>
                            <a href="https://bv-brc.org/docs/tutorial/index.html" class="analyze-button navigationLinkOut">Tutorials</a>
                        </div>
                    </div>
                </div>

                <div class="bv-brc-bottom">
                    <div class="title">
                        <h2>OUTBREAKS</h2>
                    </div>
                    <div class="outbreaks">
                        <div class="bv-brc-bottom-left card" style="flex-basis: 100% ">
                            <div class="content">
                                <h2><a href="/outbreaks/Mpox/#view_tab=overview">Mpox 2024</a></h2>
                                <div class="content-description">
                                    <div class="content-image">
                                        <img src="https://www.bv-brc.org/api/content/images/outbreaks/mpox/poxviridae_virion_image_single.png"
                                             alt="Influenza Virion">
                                    </div>
                                    <p>
                                        Monkeypox virus, the cause of Mpox, is a zoonotic disease endemic to Africa.
                                        There are two primary clades: Clade I and Clade II. Since Jan 2022, over 99,000
                                        global Mpox cases have been reported, mainly from Clade II.b. However, Clade I
                                        remains a concern with increasing outbreaks in Central Africa and recent cases
                                        outside its traditional range.
                                    </p>
                                </div>
                            </div>
                        </div>

                        <div class="bv-brc-bottom-right card" style="flex-basis: 100% ">
                            <div class="content">
                                <h2><a href="/outbreaks/H5N1/#view_tab=overview">Influenza H5N1 2024</a></h2>
                                <div class="content-description">
                                    <div class="content-image">
                                        <img src="https://www.bv-brc.org/api/content/images/outbreaks/H5N1/influenza_virion_image.png"
                                             alt="Influenza Virion">
                                    </div>
                                    <p>
                                        The H5N1 virus, known as bird flu, poses serious risks to wildlife, agriculture,
                                        and humans. Since 2020, the 2.3.4.4b strain has spread globally, with rare but
                                        severe human cases linked to infected poultry and cattle. The BV-BRC offers the
                                        latest data, outbreak maps, and resources to support research and response
                                        efforts. Learn more about the evolving outbreak and its impact.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="home-main home-main-right">
                <div class="announcements card">
                    <h2>NEWS &amp; ANNOUNCEMENTS</h2>
                    <ul class="slides" id="announcements-slides"></ul>
                    <div class="dot-navigation" id="announcements-dot-navigation"></div>
                </div>

                <div class="linkedin-feed card" id="linkedin-feed">
                    <h2 style="margin-bottom: 0;">COMMUNITY NEWS</h2>
                    <ul class="slides" id="linkedin-slides"></ul>
                    <div class="dot-navigation" id="linkedin-dot-navigation" style="margin-top: 10px;"></div>
                </div>
            </div>
        </div>
    </div>
</div>

